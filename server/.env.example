# For local handoff without creating this file, defaults are loaded from `.env.handoff` (see QUICKSTART.md).
# Same UNLOCK_KEY / MONGODB_URI defaults for minting live in `config/embedded.config.handoff.json` (see docs/desktop-unlock.md).
# Copy to `.env` and edit to override any variable.

PORT=5000
CLIENT_ORIGIN=http://localhost:5173
# 32-byte key as 64 hex characters. MUST be identical on:
#   - every machine where you run this server (copy .env or the same UNLOCK_KEY value), and
#   - the desktop unlock app that mints passcodes.
# If another PC uses a different or missing key, passcodes decrypt as invalid.
UNLOCK_KEY=
# Random secret for signing httpOnly session cookies (not the same as production DB password)
SESSION_SECRET=
# Optional: connect at startup (e.g. for local dev). If omitted, URI comes only from the decrypted passcode.
# MONGODB_URI=
